rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isPlayerInGame(data) {
      return isSignedIn() && (
        data.player1uid == request.auth.uid || data.player2uid == request.auth.uid
      );
    }

    function gameCoreFieldsUnchanged() {
      return request.resource.data.mode == resource.data.mode
        && request.resource.data.source == resource.data.source
        && request.resource.data.player1uid == resource.data.player1uid
        && request.resource.data.player2uid == resource.data.player2uid
        && request.resource.data.player1name == resource.data.player1name
        && request.resource.data.player2name == resource.data.player2name
        && request.resource.data.gridSize == resource.data.gridSize
        && request.resource.data.timerEnabled == resource.data.timerEnabled
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /players/{userId} {
      allow read: if isSignedIn();
      // Spark version: client-side ranked updates may touch both player docs.
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if isPlayerInGame(resource.data)
        || (
          isSignedIn()
          && resource.data.mode == 'casual'
          && resource.data.source == 'room'
          && resource.data.status == 'waiting'
        );

      // Casual room creation by the owner.
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.mode == 'casual'
            && request.resource.data.source == 'room'
            && request.resource.data.status == 'waiting'
            && request.resource.data.player1uid == request.auth.uid
            && request.resource.data.player2uid == null
          )
          ||
          (
            request.resource.data.source == 'matchmaking'
            && request.resource.data.status == 'active'
            && request.resource.data.gameCode == null
            && request.resource.data.player1uid != null
            && request.resource.data.player2uid != null
            && (
              request.auth.uid == request.resource.data.player1uid
              || request.auth.uid == request.resource.data.player2uid
            )
          )
        );

      // Allow joining waiting casual room by claiming player2 slot.
      allow update: if isSignedIn() && (
        (
          resource.data.mode == 'casual'
          && resource.data.source == 'room'
          && resource.data.status == 'waiting'
          && resource.data.player2uid == null
          && request.resource.data.player2uid == request.auth.uid
          && request.resource.data.status == 'active'
          && request.resource.data.player1uid == resource.data.player1uid
          && request.resource.data.mode == resource.data.mode
          && request.resource.data.source == resource.data.source
          && request.resource.data.gridSize == resource.data.gridSize
          && request.resource.data.timerEnabled == resource.data.timerEnabled
          && request.resource.data.createdAt == resource.data.createdAt
        )
        ||
        (
          isPlayerInGame(resource.data)
          && gameCoreFieldsUnchanged()
        )
      );

      allow delete: if false;
    }

    // Spark version queue: client-side matching with transactional updates.
    match /matchmakingQueue/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || (
          resource.data.status == 'searching'
          && request.resource.data.status == 'matched'
          && request.resource.data.matchedWith == request.auth.uid
          && request.resource.data.gameId is string
        )
      );
      allow delete: if false;
    }
  }
}
